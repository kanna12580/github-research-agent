# Docker Compose project
COMPOSE_PROJECT_NAME=deepintel

# LLM
LLM_PROVIDER=qwen
LLM_MODEL=qwen3.5-flash
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# 可选：让 Docker 容器通过宿主机代理访问外部 API。
# 示例：http://host.docker.internal:7890
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_NO_PROXY=db,redis,localhost,127.0.0.1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# Optional fallback LLM
LLM_FALLBACK_PROVIDER=deepseek
LLM_FALLBACK_MODEL=deepseek-chat
LLM_FALLBACK_API_KEY=

# Host-side app access
DATABASE_URL=postgresql://deepintel:deepintel_secret@localhost:5433/deepintel
REDIS_URL=redis://localhost:6379/0

# Docker internal service access
DOCKER_DATABASE_URL=postgresql://deepintel:deepintel_secret@db:5432/deepintel
DOCKER_REDIS_URL=redis://redis:6379/0

# Database container
POSTGRES_DB=deepintel
POSTGRES_USER=deepintel
POSTGRES_PASSWORD=deepintel_secret
POSTGRES_PORT=5433

# Redis container
REDIS_PORT=6379

# RAG
RAG_EMBED_MODEL=BAAI/bge-m3
RAG_EMBED_DIMENSION=1024
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_DEVICE=cpu
RAG_RETRIEVAL_TOP_K=20
RAG_RERANK_TOP_N=10
RAG_RRF_K=60

# Browser
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_POOL_SIZE=2
PLAYWRIGHT_NAVIGATION_TIMEOUT=30000

# API / Frontend ports
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_LOG_LEVEL=INFO
FRONTEND_PORT=5173
